# Zkopíruj do .env a doplň hodnoty (.env je gitignorovaný).

# --- Databáze: Supabase PostgreSQL (Prisma) ---
# Ze Supabase → tlačítko Connect:
#   DATABASE_URL = Transaction pooler (port 6543) + ?pgbouncer=true  — běh aplikace (serverless)
#   DIRECT_URL   = Session / Direct connection (port 5432)           — migrace (prisma db push)
DATABASE_URL="postgresql://postgres.<ref>:<HESLO>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<HESLO>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase browser client (volitelné) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- AI asistent (tainy Pro). Prázdné = ukázkový režim. ---
ANTHROPIC_API_KEY=
